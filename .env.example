# =============================================================================
# MARKETPLACE MANAGER — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# NUNCA comite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# Ambiente: development | production | testing
APP_ENV=development

# Chave secreta para sessões e tokens. Gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Ativa o servidor de desenvolvimento com reload automático (0 ou 1)
FLASK_DEBUG=0

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------

# PostgreSQL em produção. Em desenvolvimento, SQLite é usado como fallback.
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Senha do PostgreSQL local (deve coincidir com POSTGRES_PASSWORD no docker-compose):
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/marketplace

# -----------------------------------------------------------------------------
# REDIS (Rate Limiting)
# -----------------------------------------------------------------------------

# Usado pelo Flask-Limiter para armazenar contadores de requisições.
# Em desenvolvimento, memória local é usada como fallback (sem Redis).
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# E-MAIL (Flask-Mail)
# -----------------------------------------------------------------------------

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# -----------------------------------------------------------------------------
# CRIPTOGRAFIA DE CREDENCIAIS AMAZON
# -----------------------------------------------------------------------------

# Chave Fernet para criptografar credenciais Amazon em repouso.
# Obrigatória para usar a integração Amazon (desenvolvimento e produção).
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: defina esta chave ANTES de rodar "flask db upgrade" na migration
# f1a2b3c4d5e6 para que credenciais existentes sejam migradas automaticamente.
CREDENTIALS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# INTEGRAÇÃO AMAZON SP-API (opcional — configure via interface do app)
# -----------------------------------------------------------------------------

# As credenciais Amazon são configuradas pelo usuário dentro do próprio app
# e armazenadas criptografadas no banco de dados. Não é necessário definir
# variáveis de ambiente para isso.
